{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": "container",
  "data": {
    "url": "https://raw.githubusercontent.com/izmaisabot/A2_FIT2179/refs/heads/main/datasets/blood_donations_state.csv",
    "format": { "type": "csv" }
  },
  "params": [
    {
      "name": "year_filter",
      "value": 2024,
      "bind": { "input": "select", "options": [2022, 2023, 2024], "name": "Select Year: " }
    }
  ],
  "transform": [
    { "filter": "datum.blood_type === 'all'" },
    { "filter": "year(datum.date) == year_filter" },
    {
      "aggregate": [{ "op": "sum", "field": "donations", "as": "total_daily_donations" }],
      "groupby": ["date"]
    }
  ],
  "mark": { "type": "rect", "cornerRadius": 2, "stroke": "white", "strokeWidth": 0.5 },
  "encoding": {
    "x": {
      "field": "date",
      "timeUnit": "week",
      "type": "ordinal",
      "title": "Week of Year",
      "axis": { "labelAngle": 0, "format": "%b", "tickCount": 12 }
    },
    "y": {
      "field": "date",
      "timeUnit": "day",
      "type": "ordinal",
      "title": "Day of Week",
      "sort": ["mon", "tue", "wed", "thu", "fri", "sat", "sun"]
    },
    "color": {
      "field": "total_daily_donations",
      "type": "quantitative",
      "scale": { "scheme": "purpleblue" },
      "legend": { "title": "Donations", "format": "~s" }
    },
    "tooltip": [
      { "field": "date", "type": "temporal", "title": "Date", "format": "%A, %d %b %Y" },
      { "field": "total_daily_donations", "type": "quantitative", "title": "National Total", "format": "," }
    ]
  },
  "config": {
    "view": { "stroke": null },
    "axis": { "domain": false, "ticks": false }
  }
}