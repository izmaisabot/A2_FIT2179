{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": "container",
  "data": {
    "url": "https://raw.githubusercontent.com/izmaisabot/A2_FIT2179/refs/heads/main/datasets/blood_donations.csv",
    "format": { "type": "csv" }
  },
  "transform": [
    { "filter": "datum.blood_type !== 'all'" },
    { "filter": "year(datum.date) >= 2010" },
    {
      "window": [{ "op": "mean", "field": "donations", "as": "rolling_mean" }],
      "frame": [-3, 3],
      "groupby": ["blood_type"],
      "sort": [{"field": "date"}]
    },
    { "calculate": "upper(datum.blood_type)", "as": "BT_Upper" }
  ],
  "mark": { "type": "line", "strokeWidth": 1.8, "opacity": 0.85, "interpolate": "monotone" },
  "encoding": {
    "x": {
      "field": "date",
      "type": "temporal",
      "title": "Date",
      "axis": { "format": "%Y", "labelAngle": 0, "grid": false }
    },
    "y": {
      "field": "rolling_mean",
      "type": "quantitative",
      "title": "Donations (7-day avg)",
      "scale": {"zero": false}
    },
    "color": {
      "field": "BT_Upper",
      "type": "nominal",
      "title": "Blood Type",
      "scale": {
        "domain": ["A", "B", "AB", "O"],
        "range": ["#e41a1c", "#377eb8", "#4daf4a", "#984ea3"]
      }
    },
    "tooltip": [
      { "field": "date", "type": "temporal", "title": "Date", "format": "%d %b %Y" },
      { "field": "BT_Upper", "type": "nominal", "title": "Blood Type" },
      { "field": "rolling_mean", "type": "quantitative", "title": "7-day Avg", "format": ".0f" }
    ]
  },
  "params": [
    {
      "name": "brush",
      "select": { "type": "interval", "encodings": ["x"] }
    }
  ]
}