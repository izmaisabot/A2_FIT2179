{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": "container",
  "data": {
    "url": "https://raw.githubusercontent.com/izmaisabot/A2_FIT2179/refs/heads/main/datasets/blood_donations_state.csv",
    "format": { "type": "csv" }
  },
  "params": [
    {
      "name": "year_selection",
      "value": 2024,
      "bind": {
        "input": "range",
        "min": 2006,
        "max": 2024,
        "step": 1,
        "name": "Year: "
      }
    }
  ],
  "transform": [
    { "calculate": "year(datum.date)", "as": "year_field" },
    { "filter": "datum.year_field == year_selection" },
    { "filter": "datum.blood_type !== 'all'" },
    { "calculate": "upper(datum.blood_type)", "as": "Blood Type" },
    {
      "aggregate": [{ "op": "sum", "field": "donations", "as": "total" }],
      "groupby": ["Blood Type", "year_field"]
    },
    {
      "window": [{ "op": "sum", "field": "total", "as": "grand_total" }],
      "frame": [null, null]
    },
    {
      "calculate": "datum.total / datum.grand_total",
      "as": "percentage"
    }
  ],
  "layer": [
    {
      "mark": { "type": "arc", "innerRadius": 80, "outerRadius": 140, "stroke": "white" },
      "encoding": {
        "theta": { "field": "total", "type": "quantitative", "stack": true},
        "order": { "field": "Blood Type", "type": "nominal", "sort": "ascending"},
        "color": {
          "field": "Blood Type",
          "type": "nominal",
          "scale": {
            "domain": ["A", "B", "AB", "O"],
            "range": ["#674a40", "#50a3a4", "#fcaf38", "#f95335"]
          }
        }
      }
    },
    {
      "mark": { "type": "text", "radius": 165, "fontSize": 12 },
      "encoding": {
        "theta": { "field": "total", "type": "quantitative", "stack": true, "bandPosition": 0.5},
        "order": { "field": "Blood Type", "type": "nominal", "sort": "ascending"},
        "text": { "field": "percentage", "type": "quantitative", "format": ".1%" }
      }
    },
    {
      "mark": {
        "type": "text",
        "fontSize": 32,
        "color": "#444"
      },
      "encoding": {
        "text": { "field": "year_field", "type": "nominal" }
      }
    }
  ],
  "view": { "stroke": null }
}