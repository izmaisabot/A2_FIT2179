{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": "container",
  "projection": { "type": "mercator" },
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/jnewbery/CartogramMalaysia/refs/heads/master/public/data/malaysia-states.topojson",
        "format": { "type": "topojson", "feature": "states" }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#f2f2f2",
        "stroke": "#d1d1d1",
        "strokeWidth": 1
      }
    },
    {
      "data": {
        "values": [
          { "state": "Johor", "donations": 45764, "donor_rate": 1.09, "lat": 1.9, "lon": 103.3 },
          { "state": "Kedah", "donations": 20815, "donor_rate": 0.93, "lat": 6.0, "lon": 100.5 },
          { "state": "Kelantan", "donations": 18992, "donor_rate": 1.0, "lat": 5.3, "lon": 102.0 },
          { "state": "Melaka", "donations": 29387, "donor_rate": 2.79, "lat": 2.3, "lon": 102.3 },
          { "state": "Negeri Sembilan", "donations": 16736, "donor_rate": 1.34, "lat": 2.7, "lon": 102.2 },
          { "state": "Pahang", "donations": 24200, "donor_rate": 1.44, "lat": 3.8, "lon": 102.5 },
          { "state": "Perak", "donations": 46449, "donor_rate": 1.8, "lat": 4.7, "lon": 101.1 },
          { "state": "Pulau Pinang", "donations": 43035, "donor_rate": 2.39, "lat": 5.35, "lon": 100.3 },
          { "state": "Sabah", "donations": 40274, "donor_rate": 1.07, "lat": 5.4, "lon": 114.3 },
          { "state": "Sarawak", "donations": 41861, "donor_rate": 1.65, "lat": 2.5, "lon": 110.6 },
          { "state": "Selangor", "donations": 32151, "donor_rate": 0.43, "lat": 3.3, "lon": 101.4 },
          { "state": "Terengganu", "donations": 20769, "donor_rate": 1.67, "lat": 4.8, "lon": 103.0 },
          { "state": "W.P. Kuala Lumpur", "donations": 206856, "donor_rate": 9.97, "lat": 3.14, "lon": 101.69 }
        ]
      },
      "mark": { "type": "circle", "opacity": 0.8, "stroke": "white", "strokeWidth": 1 },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude": { "field": "lat", "type": "quantitative" },
        "size": {
          "field": "donations",
          "type": "quantitative",
          "scale": { "range": [50, 4500] },
          "legend": { 
            "title": "Total Donations", 
            "format": ",", 
            "orient": "none",
            "legendX": 220,
            "legendY": 380,
            "direction": "horizontal",
            "values": [0, 50000, 100000, 150000, 200000],
            "labelExpr": "format(datum.value, ',')",
            "symbolFillColor": "rgba(0,0,0,0.05)",
            "symbolStrokeColor": "gray"
          }
        },
        "color": {
          "field": "donor_rate",
          "type": "quantitative",
          "scale": { 
            "scheme": "reds", 
            "domain": [0, 10]
          },
          "legend": { 
            "title": "Donor Rate (%)", 
            "orient": "none",
            "legendX": 0,
            "legendY": 380,
            "direction": "horizontal",
            "values": [0, 2, 4, 6, 8, 10],
            "gradientLength": 180
          }
        },
        "tooltip": [
          { "field": "state", "type": "nominal", "title": "State" },
          { "field": "donations", "type": "quantitative", "title": "Total Donations", "format": "," },
          { "field": "donor_rate", "type": "quantitative", "title": "Donor Rate (%)", "format": ".2f" }
        ]
      }
    }
  ],
  "config": { 
    "view": { "stroke": null },
    "legend": { "labelFontSize": 10, "titleFontSize": 11 }
  }
}